   "source": [
    "\n",
    "st = input(\"Enter string:\")\n",
    "rev = \"\" \n",
    "for digit in st:\n",
    "    rev = digit+rev\n",
    "\n",
    "if st == rev:\n",
    "    print(\"palindrome\")\n",
    "else:\n",
    "    print(\"not palindrome\")\n"
   ]
